{
  "manifest_version": 3,
  "name": "九安智能采集",
  "short_name": "九安采集",
  "version": "0.9.11",
  "description": "九安智能采集：修复 Windows 角色打包脚本编码与路径问题，支持按 1/2/3 角色生成专用插件包。",
  "minimum_chrome_version": "102",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "downloads",
    "cookies",
    "webRequest",
    "debugger",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://store.weixin.qq.com/*",
    "https://fxg.jinritemai.com/*",
    "https://doudian-sso.jinritemai.com/*",
    "https://pigeon.jinritemai.com/*",
    "https://mms.pinduoduo.com/*",
    "https://mms.pdd.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "打开九安智能采集",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}